{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "functions": {
    "api/index.ts": {
      "maxDuration": 30
    }
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/screenshots/(.*)",
      "dest": "/api/index.ts"
    },
    {
      "src": "/pages/(.*)",
      "dest": "/api/index.ts"
    }
  ]
}
